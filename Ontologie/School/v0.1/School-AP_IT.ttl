###  https://w3id.org/italia/onto/School/haPuntoDiErogazioneDelServizio
<https://w3id.org/italia/onto/School/haPuntoDiErogazioneDelServizio> rdf:type owl:ObjectProperty ;
                                                                     rdfs:domain <https://w3id.org/italia/onto/School/IstitutoDiRiferimento> ;
                                                                     rdfs:range <https://w3id.org/italia/onto/School/PuntoDiErogazioneDelServizio> ;
                                                                     <http://purl.org/dc/terms/identifier> "https://w3id.org/italia/onto/School/haPuntoDiErogazioneDelServizio" ;
                                                                     rdfs:comment "Relation linking a Main Institute to the physical location (branch, detached premises, or annex) where the educational service is actually delivered."@en ,
                                                                                  "Relazione che collega un Istituto di Riferimento al punto fisico (plesso, sede distaccata o succursale) in cui viene effettivamente erogato il servizio scolastico."@it ;
                                                                     rdfs:isDefinedBy <https://w3id.org/italia/onto/School> ;
                                                                     rdfs:label "ha Punto Di Erogazione Del Servizio"@en ,
                                                                                "ha Punto Di Erogazione Del Servizio"@it ,
                                                                                "ha punto di erogazione del servizio"@it ,
                                                                                "has service delivery point"@en ;
                                                                     owl:versionInfo "provvisoria"@it ,
                                                                                     "unstable"@en .


###  https://w3id.org/italia/onto/School/haPuntoDiErogazioneDiSezioneSeraleOCarceraria
<https://w3id.org/italia/onto/School/haPuntoDiErogazioneDiSezioneSeraleOCarceraria> rdf:type owl:ObjectProperty ;
                                                                                    rdfs:subPropertyOf <https://w3id.org/italia/onto/School/haPuntoDiErogazioneDelServizio> ;
                                                                                    rdfs:domain [ rdf:type owl:Class ;
                                                                                                  owl:unionOf ( <https://w3id.org/italia/onto/School/IstitutoProfessionale>
                                                                                                                <https://w3id.org/italia/onto/School/IstitutoTecnico>
                                                                                                                <https://w3id.org/italia/onto/School/Liceo>
                                                                                                              )
                                                                                                ] ;
                                                                                    rdfs:range [ rdf:type owl:Class ;
                                                                                                 owl:unionOf ( <https://w3id.org/italia/onto/School/SezioneCarceraria>
                                                                                                               <https://w3id.org/italia/onto/School/SezioneSerale>
                                                                                                             )
                                                                                               ] ;
                                                                                    <http://purl.org/dc/terms/identifier> "https://w3id.org/italia/onto/School/haPuntoDiErogazioneDiSezioneSeraleOCarceraria" ;
                                                                                    rdfs:comment "Relation linking a Vocational Institute, a Technical Institute, or a Lyceum to an evening or prison section where the educational service is delivered. This is a sub-property of hasServiceDeliveryPoint, specialised for delivery points dedicated to adult education in evening hours or penitentiary contexts."@en ,
                                                                                                 "Relazione che collega un Istituto Professionale, un Istituto Tecnico o un Liceo a una sezione serale o carceraria in cui viene erogato il servizio scolastico. Si tratta di una sottoproprietà di haPuntoDiErogazioneDelServizio, specializzata per i punti di erogazione rivolti all'istruzione degli adulti in orario serale o in contesti penitenziari."@it ;
                                                                                    rdfs:isDefinedBy <https://w3id.org/italia/onto/School> ;
                                                                                    rdfs:label "ha Punto Di Erogazione Di Sezione Serale O Carceraria"@en ,
                                                                                               "ha Punto Di Erogazione Di Sezione Serale O Carceraria"@it ,
                                                                                               "ha punto di erogazione di sezione serale o carceraria"@it ,
                                                                                               "has evening or prison section delivery point"@en ;
                                                                                    owl:versionInfo "provvisoria"@it ,
                                                                                                    "unstable"@en .


###  https://w3id.org/italia/onto/School/haSede
<https://w3id.org/italia/onto/School/haSede> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://w3id.org/italia/onto/School/IstituzioneScolastica> ;
                                             rdfs:range <https://w3id.org/italia/onto/School/SedeIstituzioneScolastica> ;
                                             <http://purl.org/dc/terms/identifier> "https://w3id.org/italia/onto/School/haSede" ;
                                             rdfs:comment "Relation linking an Educational Institution to its official headquarters, i.e. the physical location housing the school principal's office and the central administrative services."@en ,
                                                          "Relazione che collega un'Istituzione Scolastica alla sua sede ufficiale, ovvero il luogo fisico in cui sono stabiliti la dirigenza e i servizi amministrativi centrali."@it ;
                                             rdfs:isDefinedBy <https://w3id.org/italia/onto/School> ;
                                             rdfs:label "ha Sede"@en ,
                                                        "ha Sede"@it ,
                                                        "ha sede"@it ,
                                                        "has headquarters"@en ;
                                             owl:versionInfo "provvisoria"@it ,
                                                             "unstable"@en .


