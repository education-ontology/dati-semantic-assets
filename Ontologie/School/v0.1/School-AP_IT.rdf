    <!-- https://w3id.org/italia/onto/School/haPuntoDiErogazioneDelServizio -->


    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/School/haPuntoDiErogazioneDelServizio">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/School/IstitutoDiRiferimento"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/School/PuntoDiErogazioneDelServizio"/>
        <terms:identifier>https://w3id.org/italia/onto/School/haPuntoDiErogazioneDelServizio</terms:identifier>
        <rdfs:comment xml:lang="en">Relation linking a Main Institute to the physical location (branch, detached premises, or annex) where the educational service is actually delivered.</rdfs:comment>
        <rdfs:comment xml:lang="it">Relazione che collega un Istituto di Riferimento al punto fisico (plesso, sede distaccata o succursale) in cui viene effettivamente erogato il servizio scolastico.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/School"/>
        <rdfs:label xml:lang="en">ha Punto Di Erogazione Del Servizio</rdfs:label>
        <rdfs:label xml:lang="it">ha Punto Di Erogazione Del Servizio</rdfs:label>
        <rdfs:label xml:lang="it">ha punto di erogazione del servizio</rdfs:label>
        <rdfs:label xml:lang="en">has service delivery point</rdfs:label>
        <owl:versionInfo xml:lang="it">provvisoria</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/italia/onto/School/haPuntoDiErogazioneDiSezioneSeraleOCarceraria -->


    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/School/haPuntoDiErogazioneDiSezioneSeraleOCarceraria">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/School/haPuntoDiErogazioneDelServizio"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/onto/School/IstitutoProfessionale"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/onto/School/IstitutoTecnico"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/onto/School/Liceo"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/onto/School/SezioneCarceraria"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/onto/School/SezioneSerale"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <terms:identifier>https://w3id.org/italia/onto/School/haPuntoDiErogazioneDiSezioneSeraleOCarceraria</terms:identifier>
        <rdfs:comment xml:lang="en">Relation linking a Vocational Institute, a Technical Institute, or a Lyceum to an evening or prison section where the educational service is delivered. This is a sub-property of hasServiceDeliveryPoint, specialised for delivery points dedicated to adult education in evening hours or penitentiary contexts.</rdfs:comment>
        <rdfs:comment xml:lang="it">Relazione che collega un Istituto Professionale, un Istituto Tecnico o un Liceo a una sezione serale o carceraria in cui viene erogato il servizio scolastico. Si tratta di una sottoproprietà di haPuntoDiErogazioneDelServizio, specializzata per i punti di erogazione rivolti all&apos;istruzione degli adulti in orario serale o in contesti penitenziari.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/School"/>
        <rdfs:label xml:lang="en">ha Punto Di Erogazione Di Sezione Serale O Carceraria</rdfs:label>
        <rdfs:label xml:lang="it">ha Punto Di Erogazione Di Sezione Serale O Carceraria</rdfs:label>
        <rdfs:label xml:lang="it">ha punto di erogazione di sezione serale o carceraria</rdfs:label>
        <rdfs:label xml:lang="en">has evening or prison section delivery point</rdfs:label>
        <owl:versionInfo xml:lang="it">provvisoria</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/italia/onto/School/haSede -->


    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/School/haSede">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/School/IstituzioneScolastica"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/School/SedeIstituzioneScolastica"/>
        <terms:identifier>https://w3id.org/italia/onto/School/haSede</terms:identifier>
        <rdfs:comment xml:lang="en">Relation linking an Educational Institution to its official headquarters, i.e. the physical location housing the school principal&apos;s office and the central administrative services.</rdfs:comment>
        <rdfs:comment xml:lang="it">Relazione che collega un&apos;Istituzione Scolastica alla sua sede ufficiale, ovvero il luogo fisico in cui sono stabiliti la dirigenza e i servizi amministrativi centrali.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/School"/>
        <rdfs:label xml:lang="en">ha Sede</rdfs:label>
        <rdfs:label xml:lang="it">ha Sede</rdfs:label>
        <rdfs:label xml:lang="it">ha sede</rdfs:label>
        <rdfs:label xml:lang="en">has headquarters</rdfs:label>
        <owl:versionInfo xml:lang="it">provvisoria</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


